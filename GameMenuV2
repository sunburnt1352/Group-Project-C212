    void showWordGM2(gameMode2 gameInstance, JButton letter, List<String> word, int index){
        if(index<word.size()){
            ScheduledExecutorService executorService = Executors.newSingleThreadScheduledExecutor();
            executorService.schedule(() -> {
                ImageIcon currLetter=gameInstance.getLetter(word.get(index));
                changeImage(currLetter,letter);
                showWordGM2(gameInstance, letter, word, (index+1) );

            }, 1, TimeUnit.SECONDS);
        }
        if(index==word.size()){
            getAnswerForGM2(gameInstance);
        }
    }

